// MENSAJE RECIBIDO 

void handleMessage(AdafruitIO_Data *data) {

  int numero = data->toInt();

  Serial.print("Numero recibido: ");
  Serial.println(numero);

  mostrarAlien();
}


// SETUP 

void setup() {

  pinMode(BOTON_PIN, INPUT_PULLUP);

  Serial.begin(115200);

  // OLED
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {

    Serial.println("OLED no encontrada");
    while (1);
  }

  display.clearDisplay();
  display.display();

  // Conexion Adafruit IO
  io.connect();

  // Leer mensajes
  feed->onMessage(handleMessage);

  Serial.print("Conectando a Adafruit IO");

  while (io.status() < AIO_CONNECTED) {

    Serial.print(".");
    delay(500);
  }

  Serial.println();
  Serial.println("Conectado!");

  // Obtener ultimo dato
  feed->get();
}

// LOOP 

void loop() {

  bool boton = digitalRead(BOTON_PIN);

  if (boton == LOW) {

    io.run();
  }
}