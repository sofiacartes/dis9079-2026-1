const int BOTON_PIN = 2;



// FUNCIONES 

void mostrarAlien() {

  display.clearDisplay();
  display.drawBitmap(
    0, 0,
    alienFrame1,
    128, 64,
    WHITE
  );
  display.display();

  delay(120);

  display.clearDisplay();
  display.drawBitmap(
    0, 0,
    alienFrame2,
    128, 64,
    WHITE
  );
  display.display();

  delay(120);

